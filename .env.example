# Gmail SMTP Configuration for OTP and Email Notifications
# Copy this file to .env for local development
# For Streamlit Cloud, add these to Secrets management

# Gmail account for sending emails
GMAIL_SMTP_USER=your_email@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# Generate one at: https://myaccount.google.com/apppasswords
GMAIL_SMTP_PASSWORD=your_16_character_app_password

# Application URL (for email links)
APP_URL=http://localhost:8501

# For Streamlit Cloud, use this format in Secrets:
# [email]
# smtp_user = "your_email@gmail.com"
# smtp_password = "your_app_password"
#
# [app]
# url = "https://your-app.streamlit.app"
